  "scripts": {
    "start": "node index.js && node visualizer.js",
    "screen-rut": "node --use-system-ca --experimental-specifier-resolution=node scripts/screenIndex.js rut",
    "screen-dji": "node --use-system-ca --experimental-specifier-resolution=node scripts/screenIndex.js dji",
    "screen-ndx": "node --use-system-ca --experimental-specifier-resolution=node scripts/screenIndex.js ndx",
    "screen-sp100": "node --use-system-ca --experimental-specifier-resolution=node scripts/screenIndex.js sp100",
    "screen-all": "node --use-system-ca --experimental-specifier-resolution=node scripts/screenIndex.js all",
    "setup": "node scripts/createWorkbook.js && node --use-system-ca --experimental-specifier-resolution=node scripts/screenIndex.js all",    
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "echo \"Error: no test specified\" && exit 1",
